# Copia este archivo a .env en el VPS: cp .env.prod.example .env

# Dominio público (sin barra final). Usado en CORS del backend.
FRONTEND_URL=https://lrjasmerida.me

# Puerto HTTP expuesto en el VPS (80 = acceso directo por dominio)
HTTP_PORT=80

# PostgreSQL
POSTGRES_USER=lrjas
POSTGRES_PASSWORD=cambia_esta_contraseña_larga
POSTGRES_DB=lrjas

# JWT — genera uno aleatorio: openssl rand -base64 48
JWT_SECRET=cambia_este_secreto_jwt
JWT_EXPIRES_IN=7d

# Usuario admin inicial (solo si la BD está vacía)
MASTER_USER_USERNAME=alan
MASTER_USER_NAME=Alan
MASTER_USER_PASSWORD=cambia_esta_contraseña_admin
